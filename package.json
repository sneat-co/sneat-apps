{
  "name": "sneat-apps",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "nx": "NODE_OPTIONS=--no-deprecation nx",
    "ng": "nx",
    "oxlint": "oxlint",
    "oxlint:fix": "oxlint --fix",
    "postinstall_legacy": "node ./decorate-angular-cli.js && ngcc --properties es2022 browser module main --first-only --create-ivy-entry-points",
    "start": "nx serve",
    "build": "nx build",
    "build:ci": "nx build",
    "test": "nx test",
    "prepare": "git config core.hooksPath .git-hooks || echo 'Not in a git repo'",
    "firebase-emulators:dev": "cross-env firebase emulators:start --only auth,firestore --config ../sneat-go-backend/firebase/firebase.json",
    "firebase-emulators:ci": "cross-env firebase emulators:start --only auth,firestore --config ../../_actions/sneat-co/sneat-go-backend/main/firebase/firebase-ci.json",
    "pw:pretest": "tsc --incremental -p tests/tsconfig.json",
    "pw:test": "playwright test tests -c tests-out",
    "serve:help": "serve --help",
    "coverage:analyze": "node scripts/list-uncovered-lines.mjs",
    "coverage:analyze:run": "node scripts/list-uncovered-lines.mjs --run-tests",
    "coverage:report": "node scripts/generate-coverage-report.mjs",
    "coverage:report:run": "node scripts/generate-coverage-report.mjs --run-tests"
  },
  "private": true,
