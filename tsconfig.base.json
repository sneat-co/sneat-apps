{
  "extends": "./tsconfig.json",
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "incremental": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "useDefineForClassFields": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "lib": ["ES2023", "DOM"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@sneat/communes-ui": ["libs/communes/ui/src/index.ts"],
      "@sneat/core/testing-base": [
        "libs/testing/src/base-test-setup.ts"
      ],
      "@sneat/core/testing": ["libs/testing/src/test-setup.ts"],
      "@sneat/core/testing-light": [
        "libs/testing/src/test-setup-light.ts"
      ],
"@sneat/datetime": ["libs/datetime/src/index.ts"],
      "@sneat/ext-debtus-internal": [
        "libs/extensions/debtus/internal/src/index.ts"
      ],
      "@sneat/ext-debtus-shared": [
        "libs/extensions/debtus/shared/src/index.ts"
      ],
      "@sneat/ext-meeting": ["libs/meeting/src/index.ts"],
      "@sneat/ext-scrumspace-dailyscrum": [
        "libs/scrumspace/dailyscrum/src/index.ts"
      ],
      "@sneat/ext-scrumspace-retrospectives": [
        "libs/scrumspace/retrospectives/src/index.ts"
      ],
      "@sneat/ext-scrumspace-scrummodels": [
        "libs/scrumspace/scrummodels/src/index.ts"
      ],
      "@sneat/extensions-assetus-pages": [
        "libs/extensions/assetus/pages/src/index.ts"
      ],
      "@sneat/extensions-budgetus": ["libs/extensions/budgetus/src/index.ts"],
      "@sneat/extensions-docus": ["libs/extensions/docus/src/index.ts"],
      "@sneat/extensions-listus": ["libs/extensions/listus/src/index.ts"],
      "@sneat/extensions-logist": ["libs/extensions/logist/src/index.ts"],
      "@sneat/extensions-trackus": ["libs/extensions/trackus/src/index.ts"],
      "@sneat/space-pages": ["libs/space/pages/src/index.ts"],
      "@sneat/timer": ["libs/timer/src/index.ts"],
      "@sneat/user": ["libs/user/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
